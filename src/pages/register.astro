---
// Register page
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Crear cuenta | Mi Protocolo</title>
  </head>
  <body class="bg-cream text-gray-900 min-h-screen flex flex-col">
    <div class="bg-forest text-cream px-6 py-8">
      <h1 class="text-2xl font-bold">Mi Protocolo</h1>
      <p class="text-sm opacity-80 mt-1">Crea tu cuenta gratuita</p>
    </div>

    <div class="flex-1 max-w-md mx-auto w-full px-4 py-8">
      <form id="register-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="name">
            Tu nombre
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-forest"
            placeholder="Dr. Juan Pérez"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="email">
            Correo electrónico
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-forest"
            placeholder="tu@email.com"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="password">
            Contraseña
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="new-password"
            minlength="8"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-forest"
            placeholder="Mínimo 8 caracteres"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Perfil de salud
          </label>
          <select
            id="health_profile"
            name="health_profile"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-forest"
          >
            <option value="general">General</option>
            <option value="periodontitis">Periodontitis</option>
            <option value="diabetes">Diabetes</option>
            <option value="amalgamas">Amalgamas</option>
            <option value="madre">Madre</option>
            <option value="preventivo">Preventivo</option>
          </select>
        </div>

        <div id="error-msg" class="hidden text-red-600 text-sm bg-red-50 rounded-lg p-3"></div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-forest hover:bg-forest-dark text-white font-semibold py-3 px-6 rounded-xl transition-colors"
        >
          Crear cuenta
        </button>
      </form>

      <div class="mt-6 text-center">
        <p class="text-sm text-gray-500">
          ¿Ya tienes cuenta?
          <a href="/login" class="text-forest font-medium hover:underline">Inicia sesión</a>
        </p>
      </div>

      <div class="mt-8 text-center">
        <a href="/" class="text-xs text-gray-400 hover:text-forest transition-colors">
          ← Volver al inicio
        </a>
      </div>
    </div>

    <script>
      const form = document.getElementById('register-form') as HTMLFormElement;
      const errorMsg = document.getElementById('error-msg')!;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="animate-pulse">Creando cuenta...</span>';

        const name = (document.getElementById('name') as HTMLInputElement).value;
        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;
        const healthProfile = (document.getElementById('health_profile') as HTMLSelectElement).value;

        try {
          // Register user
          const res = await fetch('http://64.176.16.231:8090/api/collections/users/records', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email,
              password,
              passwordConfirm: password,
              name,
              health_profile: healthProfile
            })
          });

          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.message || 'Error al crear cuenta');
          }

          // Auto-login after register
          const loginRes = await fetch('http://64.176.16.231:8090/api/collections/users/auth-with-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ identity: email, password })
          });

          if (!loginRes.ok) {
            throw new Error('Cuenta creada. Por favor inicia sesión.');
          }

          const data = await loginRes.json();
          localStorage.setItem('pb_auth', JSON.stringify(data));
          window.location.href = '/app/biblioteca';
        } catch (err: any) {
          errorMsg.textContent = err.message;
          errorMsg.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<span>Crear cuenta</span>';
        }
      });
    </script>
  </body>
</html>
