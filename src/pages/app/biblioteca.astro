---
import AppLayout from '@layouts/AppLayout.astro';

const PB_URL = import.meta.env.PUBLIC_PB_URL || 'http://64.176.16.231:8090';

// Fetch chapters
let chapters: any[] = [];
try {
  const res = await fetch(`${PB_URL}/api/collections/chapters/records?perPage=50&sort=orden`);
  if (res.ok) {
    const data = await res.json();
    chapters = data.items || [];
  }
} catch (e) {
  chapters = [];
}

// Group chapters by capa
const capas = {
  raices: chapters.filter((c: any) => c.capa === 'raices'),
  territorio: chapters.filter((c: any) => c.capa === 'territorio'),
  yagan: chapters.filter((c: any) => c.capa === 'yagan')
};

const capaInfo = {
  raices: { label: '🌱 Raíces', desc: 'Gratis — Fundamentos evolutivos', tier: 'free' },
  territorio: { label: '🌿 Territorio', desc: 'Desbloquea con 70% adherencia', tier: 'premium' },
  yagan: { label: '🏔️ Yagán', desc: 'Completa Territorio primero', tier: 'vip' }
};
---

<AppLayout title="Biblioteca">
  <div class="max-w-md mx-auto px-4 py-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Biblioteca</h1>
      <p class="text-sm text-gray-500 mt-1">Contenido del libro Salud Evolutiva</p>
    </div>

    <!-- Free access chapters (Raíces) -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">🌱</span>
        <h2 class="text-base font-semibold text-gray-800">Capa Raíces</h2>
        <span class="text-xs bg-forest/10 text-forest px-2 py-0.5 rounded-full">Gratis</span>
      </div>

      <div class="space-y-3">
        {capas.raices.map((chapter: any) => (
          <a
            href={`/app/capitulo/${chapter.slug}`}
            class="block bg-white rounded-xl p-4 border border-gray-100 hover:border-forest transition-all shadow-sm"
          >
            <div class="flex items-start gap-3">
              <div class="flex-1">
                <p class="text-xs text-forest font-medium mb-0.5 uppercase tracking-wide">
                  {chapter.seccion?.replace('_', ' ')}
                </p>
                <h3 class="font-semibold text-gray-900 text-sm leading-snug">
                  {chapter.title}
                </h3>
                <p class="text-xs text-gray-500 mt-1 line-clamp-2">
                  {chapter.resumen?.substring(0, 120)}...
                </p>
              </div>
              <span class="text-gray-300">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Territorio (locked for now — logic shown) -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">🌿</span>
        <h2 class="text-base font-semibold text-gray-800">Capa Territorio</h2>
        <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Premium</span>
      </div>
      <div class="bg-gradient-to-r from-amber-50 to-orange-50 rounded-xl p-4 border border-amber-200">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🔒</span>
          <div>
            <p class="text-sm font-medium text-gray-800">Contenido bloqueado</p>
            <p class="text-xs text-gray-600 mt-0.5">
              Completa la Capa Raíces y mantén 70% de adherencia diaria para desbloquear.
            </p>
          </div>
        </div>
        <div class="mt-3 bg-amber-200/50 rounded-lg p-2">
          <p class="text-xs text-amber-800 font-medium">📊 Tu progreso en Raíces</p>
          <div class="mt-1 h-2 bg-amber-200 rounded-full overflow-hidden">
            <div class="h-full bg-forest rounded-full" style="width: 0%"></div>
          </div>
          <p class="text-xs text-amber-700 mt-1">0% — Lee los capítulos gratuitos para empezar</p>
        </div>
      </div>

      <div class="space-y-3 mt-3 opacity-60 pointer-events-none">
        {capas.territorio.map((chapter: any) => (
          <div class="block bg-gray-50 rounded-xl p-4 border border-gray-100">
            <div class="flex items-start gap-3">
              <div class="flex-1">
                <p class="text-xs text-gray-400 mb-0.5 uppercase tracking-wide">{chapter.seccion?.replace('_', ' ')}</p>
                <h3 class="font-semibold text-gray-400 text-sm">{chapter.title}</h3>
              </div>
              <span>🔒</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Yagán (VIP — locked) -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">🏔️</span>
        <h2 class="text-base font-semibold text-gray-800">Capa Yagán</h2>
        <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">VIP</span>
      </div>
      <div class="bg-purple-50 rounded-xl p-4 border border-purple-200 opacity-60">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🔐</span>
          <div>
            <p class="text-sm font-medium text-gray-700">Contenido VIP</p>
            <p class="text-xs text-gray-500 mt-0.5">Completa Territorio para acceder a esta capa.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
