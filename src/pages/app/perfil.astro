---
import AppLayout from '@layouts/AppLayout.astro';
---

<AppLayout title="Mi Perfil">
  <div class="max-w-md mx-auto px-4 py-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Mi Perfil</h1>
    </div>

    <!-- User card -->
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm mb-5" id="user-card">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-14 h-14 rounded-full bg-forest flex items-center justify-center text-white text-xl font-bold" id="avatar">
          U
        </div>
        <div>
          <p class="font-semibold text-gray-900" id="user-name">Cargando...</p>
          <p class="text-xs text-gray-500" id="user-email">—</p>
        </div>
      </div>

      <div class="space-y-3">
        <div>
          <label class="text-xs text-gray-500 block mb-1">Perfil de salud</label>
          <select
            id="health-profile-select"
            class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm bg-cream focus:outline-none focus:ring-2 focus:ring-forest"
          >
            <option value="general">General</option>
            <option value="periodontitis">Periodontitis</option>
            <option value="diabetes">Diabetes</option>
            <option value="amalgamas">Amalgamas</option>
            <option value="madre">Madre</option>
            <option value="preventivo">Preventivo</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-3 mb-5">
      {[
        { label: 'Capítulos', value: '3/12', icon: '📖' },
        { label: 'Días activos', value: '0', icon: '📅' },
        { label: 'Racha', value: '0', icon: '🔥' }
      ].map(stat => (
        <div class="bg-white rounded-xl p-3 border border-gray-100 text-center">
          <span class="text-xl block mb-1">{stat.icon}</span>
          <p class="text-lg font-bold text-gray-900">{stat.value}</p>
          <p class="text-xs text-gray-500">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Actions -->
    <div class="space-y-3">
      <a
        href="/app/ajustes"
        class="flex items-center justify-between bg-white rounded-xl p-4 border border-gray-100 hover:border-forest transition-colors"
      >
        <span class="text-sm font-medium text-gray-700">⚙️ Ajustes</span>
        <span class="text-gray-300">→</span>
      </a>
      <button
        id="logout-btn"
        class="w-full flex items-center justify-between bg-white rounded-xl p-4 border border-gray-100 hover:border-red-300 transition-colors text-left"
      >
        <span class="text-sm font-medium text-red-600">🚪 Cerrar sesión</span>
      </button>
    </div>

    <!-- Guest prompt -->
    <div class="mt-8 p-4 bg-sand/30 rounded-xl border border-sand" id="guest-prompt" style="display:none">
      <p class="text-sm text-gray-600 text-center">
        ¿Ya tienes cuenta?
        <a href="/login" class="text-forest font-medium">Inicia sesión</a>
        o
        <a href="/register" class="text-forest font-medium">regístrate gratis</a>
      </p>
    </div>
  </div>
</AppLayout>

<script>
  const authData = localStorage.getItem('pb_auth');
  const nameEl = document.getElementById('user-name');
  const emailEl = document.getElementById('user-email');
  const avatarEl = document.getElementById('avatar');
  const guestPrompt = document.getElementById('guest-prompt');
  const healthSelect = document.getElementById('health-profile-select') as HTMLSelectElement;

  if (!authData) {
    if (guestPrompt) guestPrompt.style.display = 'block';
    (document.getElementById('user-card') as HTMLElement).style.display = 'none';
  } else {
    try {
      const { record } = JSON.parse(authData);
      if (nameEl) nameEl.textContent = record.name || 'Usuario';
      if (emailEl) emailEl.textContent = record.email || '';
      if (avatarEl) avatarEl.textContent = (record.name || 'U').charAt(0).toUpperCase();
      if (healthSelect && record.health_profile) {
        healthSelect.value = record.health_profile;
      }
    } catch {}
  }

  // Update health profile
  healthSelect?.addEventListener('change', async () => {
    const authData2 = localStorage.getItem('pb_auth');
    if (!authData2) return;
    const { token, record } = JSON.parse(authData2);
    await fetch(`http://64.176.16.231:8090/api/collections/users/records/${record.id}`, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
      },
      body: JSON.stringify({ health_profile: healthSelect.value })
    });
  });

  // Logout
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('pb_auth');
    window.location.href = '/';
  });
</script>
