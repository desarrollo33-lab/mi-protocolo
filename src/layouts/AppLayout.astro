---
import BottomNav from '@components/BottomNav.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2E7D32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Salud Evolutiva</title>
  </head>
  <body class="bg-cream text-gray-900 min-h-screen pb-20">
    <header class="bg-forest text-cream px-4 py-3 shadow-md">
      <h1 class="text-lg font-semibold">Salud Evolutiva</h1>
    </header>

    <main>
      <slot />
    </main>

    <BottomNav />
  </body>
</html>
